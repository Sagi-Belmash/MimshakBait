<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/transparent"
    android:orientation="vertical">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        style="@style/Style.TextView.ExtraBold"
        android:textColor="@color/black"
        android:text="הצטרפות למשק בית"
        android:textSize="40sp"/>

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="20dp"
        style="@style/Style.TextView.Bold"
        android:textColor="@color/black"
        android:text="סרקו ברקוד של משק בית קיים\nכדי להצטרף אליו"
        android:textSize="23sp"/>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal">

        <androidx.camera.view.PreviewView
            android:id="@+id/enter_PREVIEW_qr"
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:layout_marginHorizontal="60dp"
            android:background="@android:color/black"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/enter_IMG_qr"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="75dp"
            android:layout_centerInParent="true"
            app:srcCompat="@drawable/qr_frame"/>

    </RelativeLayout>


</androidx.appcompat.widget.LinearLayoutCompat>