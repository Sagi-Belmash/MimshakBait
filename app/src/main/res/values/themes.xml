<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MemshakBait" parent="Theme.Material3.DayNight.NoActionBar"/>

    <!-- Text -->
    <style name="Style.TextView" parent="android:Widget.TextView">
        <item name="android:textColor">@color/white</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Style.TextView.ExtraBold" parent="Style.TextView">
        <item name="fontFamily">@font/rubik_extrabold</item>
    </style>

    <style name="Style.TextView.SemiBold" parent="Style.TextView">
        <item name="fontFamily">@font/rubik_semibold</item>
    </style>

    <style name="Style.TextView.Bold" parent="Style.TextView">
        <item name="fontFamily">@font/rubik_bold</item>
    </style>

    <style name="Style.TextView.Regular" parent="Style.TextView">
        <item name="fontFamily">@font/rubik_regular</item>
    </style>

    <!-- Liquid Glass -->
    <style name="Style.LiquidGlass.Outer" parent="">
        <item name="lg_blurRadius">15</item>
        <item name="lg_overlayColor">@color/liquid_glass_outer_white</item>
    </style>

    <style name="Style.LiquidGlass.Circular" parent="@style/Style.LiquidGlass.Outer">
        <item name="lg_cornerRadius">50dp</item>
    </style>

    <style name="Style.LiquidGlass.Rectangular" parent="@style/Style.LiquidGlass.Outer">
        <item name="lg_cornerRadius">25dp</item>
    </style>

    <style name="Style.LiquidGlass.EditText" parent="">
        <item name="fontFamily">@font/rubik_semibold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:padding">16dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Style.LiquidGlass.Button" parent="">
        <item name="fontFamily">@font/rubik_semibold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="Style.LiquidGlass.Button.Unpressed" parent="Style.LiquidGlass.Button">
        <item name="backgroundTint">@color/liquid_glass_inner_20</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Style.LiquidGlass.Button.Pressed" parent="Style.LiquidGlass.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/turquoise</item>
    </style>



</resources>